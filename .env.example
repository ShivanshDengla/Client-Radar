# =====================================================================
# Reddit Client Radar - configuration
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# Never commit your real .env file (it is already in .gitignore).
# =====================================================================

# ---- Discord webhook (REQUIRED) ----
# Create in Discord: channel gear icon -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# ---- Subreddits to monitor (comma separated, no "r/" prefix) ----
# Hiring boards: forhire, jobbit, slavelabour, freelance_forhire, DoneDirtCheap,
#   FreelanceProgramming, hireaprogrammer
# Web / app dev: AppDevelopers, webdev, web_design, reactjs, nextjs, node, rails,
#   django, Wordpress, Shopify
# Mobile: flutterdev, iOSProgramming, androiddev
# Startups / business (people hire devs here too): startups, Entrepreneur,
#   smallbusiness, SaaS
SUBREDDITS=forhire,jobbit,slavelabour,freelance_forhire,DoneDirtCheap,FreelanceProgramming,hireaprogrammer,AppDevelopers,webdev,web_design,reactjs,nextjs,flutterdev,iOSProgramming,androiddev,node,rails,django,Wordpress,Shopify,startups,Entrepreneur,smallbusiness,SaaS

# ---- How many newest posts to pull per check (RSS max is ~25) ----
POST_FETCH_LIMIT=25

# ---- How often to check, in seconds (300 = every 5 minutes) ----
POLL_INTERVAL_SECONDS=300

# ---- SQLite file that remembers seen posts (no duplicates) ----
DATABASE_PATH=seen_posts.db

# ---- Optional: name shown to Reddit when fetching public RSS ----
# No login or Reddit account is used. This is just a label.
USER_AGENT=ClientRadar/1.0 (anonymous RSS monitor; no Reddit account)

# ---- Send a short "scan complete" ping to Discord after every run ----
SEND_STATUS_TO_DISCORD=true
