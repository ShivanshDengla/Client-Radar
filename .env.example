# =====================================================================
# Reddit Client Radar — copy to .env and fill in your values
#   cp .env.example .env
# =====================================================================

# ---- Discord webhook (REQUIRED) ----
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# ---- Subreddits (comma separated, no "r/" prefix) ----
SUBREDDITS=forhire,jobbit,slavelabour,freelance_forhire,DoneDirtCheap,FreelanceProgramming,hireaprogrammer,AppDevelopers,webdev,reactjs,nextjs,flutterdev,iOSProgramming,androiddev

# ---- Posts to pull per subreddit batch per run (RSS max ~25) ----
POST_FETCH_LIMIT=25

# ---- SQLite file — remembers posts between your manual runs ----
DATABASE_PATH=seen_posts.db

# ---- Short summary to Discord after each run (true/false) ----
SEND_STATUS_TO_DISCORD=true

# ---- Label sent to Reddit when fetching public RSS (no login) ----
USER_AGENT=ClientRadar/1.0 (anonymous RSS monitor; no Reddit account)

# ---- Reddit fetch tuning (optional) ----
RSS_BATCH_SIZE=3
REQUEST_DELAY_SECONDS=3
