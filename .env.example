# =====================================================================
# Reddit Client Radar - configuration
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# Never commit your real .env file (it is already in .gitignore).
# =====================================================================

# ---- Discord webhook (REQUIRED) ----
# Create in Discord: channel gear icon -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# ---- Subreddits to monitor (comma separated, no "r/" prefix) ----
SUBREDDITS=forhire,jobbit,slavelabour,freelance_forhire,DoneDirtCheap

# ---- How many newest posts to pull per check (RSS max is ~25) ----
POST_FETCH_LIMIT=25

# ---- How often to check, in seconds (300 = every 5 minutes) ----
POLL_INTERVAL_SECONDS=300

# ---- SQLite file that remembers seen posts (no duplicates) ----
DATABASE_PATH=seen_posts.db

# ---- Optional: name shown to Reddit when fetching public RSS ----
# No login or Reddit account is used. This is just a label.
USER_AGENT=ClientRadar/1.0 (anonymous RSS monitor; no Reddit account)
